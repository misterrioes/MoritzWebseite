---
import ServicePage from "@components/ServicePage.astro";
import NatursteinBlumeDesktop from "@images/NatursteinarbeitenBlume16zu9.JPG";
import NatursteinBlumeMobile from "@images/NatursteinarbeitenBlume9zu16.JPG";
import NatursteinMauerDesktop from "@images/Natursteinarbeitenckmauer16zu9.JPG";
import NatursteinBrunnenMobile from "@images/NatursteinarbeitenBrunnen9zu16.JPG";
import NatursteinJapanDesktop from "@images/NatursteinarbeitenJapan16zu9.JPG";
import NatursteinJapanMobile from "@images/NatursteinarbeitenJapan9zu16.JPG";
import NatursteinHeimMobile from "@images/NatursteinarbeitenHeim9zu16.JPG";
---

<ServicePage
    title="Natursteinarbeiten"
    description="Wir gestalten Natursteinmauern, Terrassen und Gartenbereiche mit hochwertigen Materialien und handwerklicher Präzision. Ob moderne Flächen oder rustikale Natursteinwände - wir setzen Ihre Ideen zuverlässig um."
    images={[
        {
            desktopSrc: NatursteinBlumeDesktop.src,
            mobileSrc: NatursteinBlumeMobile.src,
            alt: "Natursteinarbeiten Blume",
            textTitle: "Naturstein mit Charakter",
            text: "Naturstein bringt Charakter in Gärten und Außenanlagen. Jede Lösung wird passend zur Umgebung und zum gewünschten Stil umgesetzt.",
        },
        {
            desktopSrc: NatursteinMauerDesktop.src,
            mobileSrc: NatursteinBrunnenMobile.src,
            alt: "Natursteinarbeiten Brunnen und Mauer",
            textTitle: "Saubere Handwerksarbeit",
            text: "Von Mauern über Einfassungen bis zu Terrassen entstehen handwerklich saubere Arbeiten mit einem hochwertigen, natürlichen Eindruck.",
        },
        {
            desktopSrc: NatursteinJapanDesktop.src,
            mobileSrc: NatursteinJapanMobile.src,
            alt: "Natursteinarbeiten Japan",
            textTitle: "Langlebige Gestaltung",
            text: "Im Fokus stehen langlebige Materialien, präzise Verarbeitung und ein Ergebnis, das sich dauerhaft in Ihren Außenbereich einfügt.",
        },
        {
            mobileSrc: NatursteinHeimMobile.src,
            alt: "Natursteinarbeiten Heim",
            textTitle: "Individuelle Details",
            text: "Auch auf kleineren mobilen Ansichten bleiben zusätzliche Einblicke in verschiedene Natursteinprojekte sichtbar.",
        },
    ]}
/>
