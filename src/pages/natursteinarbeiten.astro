---
import ServicePage from "@components/ServicePage.astro";
import MoritzSchaufelnHD from "@images/16zu9HDMoritzAmSchaufeln.jpg";
import MoritzSchaufeln from "@images/16zu9MoritzAmSchaufeln.jpg";
import MoritzBagger from "@images/16zu9MoritzImAuto.jpg";
import MoritzArbeiten from "@images/16zu9Plakat.jpg";
---

<ServicePage
    title="Natursteinarbeiten"
    description="Wir gestalten Natursteinmauern, Terrassen und Gartenbereiche mit hochwertigen Materialien und handwerklicher Präzision. Ob moderne Flächen oder rustikale Natursteinwände - wir setzen Ihre Ideen zuverlässig um."
    images={[
        {
            src: MoritzSchaufeln.src,
            hdSrc: MoritzSchaufelnHD.src,
            alt: "Moritz am Schaufeln",
            textTitle: "Naturstein mit Charakter",
            text: "Naturstein bringt Charakter in Gärten und Außenanlagen. Jede Lösung wird passend zur Umgebung und zum gewünschten Stil umgesetzt.",
        },
        {
            src: MoritzBagger.src,
            alt: "Moritz im Auto",
            textTitle: "Saubere Handwerksarbeit",
            text: "Von Mauern über Einfassungen bis zu Terrassen entstehen handwerklich saubere Arbeiten mit einem hochwertigen, natürlichen Eindruck.",
        },
        {
            src: MoritzArbeiten.src,
            alt: "Plakat",
            textTitle: "Langlebige Gestaltung",
            text: "Im Fokus stehen langlebige Materialien, präzise Verarbeitung und ein Ergebnis, das sich dauerhaft in Ihren Außenbereich einfügt.",
        },
    ]}
/>
