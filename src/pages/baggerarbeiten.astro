---
import ServicePage from "@components/ServicePage.astro";
import MoritzSchaufelnHD from "@images/16zu9HDMoritzAmSchaufeln.jpg";
import MoritzSchaufeln from "@images/16zu9MoritzAmSchaufeln.jpg";
import MoritzBagger from "@images/16zu9MoritzImAuto.jpg";
import MoritzArbeiten from "@images/16zu9Plakat.jpg";
---

<ServicePage
    title="Baggerarbeiten"
    description="Wir führen Erdarbeiten, Grabungen und Landschaftsgestaltung mit modernen Maschinen und erfahrenen Bedienern aus. Präzise und zuverlässig schaffen wir die Grundlage für Ihre Bauprojekte."
    images={[
        {
            src: MoritzSchaufeln.src,
            hdSrc: MoritzSchaufelnHD.src,
            alt: "Moritz am Schaufeln",
            textTitle: "Starke Grundlage",
            text: "Baggerarbeiten schaffen die Grundlage für saubere Abläufe auf der Baustelle, vom Aushub bis zur Vorbereitung weiterer Gewerke.",
        },
        {
            src: MoritzBagger.src,
            alt: "Moritz im Auto",
            textTitle: "Präzise Erdbewegung",
            text: "Mit Erfahrung und dem passenden Gerät werden Erdbewegungen präzise, effizient und abgestimmt auf das jeweilige Projekt ausgeführt.",
        },
        {
            src: MoritzArbeiten.src,
            alt: "Plakat",
            textTitle: "Zuverlässige Umsetzung",
            text: "Ob Geländeprofil, Freilegung oder Vorbereitung für Pflaster- und Natursteinarbeiten: Die Umsetzung bleibt strukturiert und zuverlässig.",
        },
    ]}
/>
