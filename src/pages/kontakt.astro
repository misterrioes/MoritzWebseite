---
import Baselayout from "../layouts/Baselayout.astro";
import BilderKarussel from "@components/BilderKarusselText.astro";
import KontaktModal from "@components/KontaktModal.astro";
import KontaktArten from "@components/StickyContact.astro";
import { contactDetails } from "@components/contactData";
import StartseiteSchaufelnDesktop from "@images/Startseite16zu9MoritzAmSchaufeln.jpg";
import StartseiteSchaufelnMobile from "@images/StartseiteMoritzAmSchaufeln9zu16.JPG";
import StartseiteAutoDesktop from "@images/Startseite16zu9MoritzImAuto.jpg";
import StartseiteAutoMobile from "@images/StartseiteMoritzImAuto9zu16.JPG";
import StartseitePlakatDesktop from "@images/Startseite16zu9Plakat.jpg";
---

<Baselayout>
    <BilderKarussel
        title="Kontakt"
        description="Sie planen ein Projekt im Garten- oder Mauerbau? Melden Sie sich gern für eine unverbindliche Anfrage, eine erste Einschätzung oder einen Termin vor Ort."
        images={[
            {
                desktopSrc: StartseiteSchaufelnDesktop.src,
                mobileSrc: StartseiteSchaufelnMobile.src,
                alt: "Moritz bei der Arbeit",
            },
            {
                desktopSrc: StartseiteAutoDesktop.src,
                mobileSrc: StartseiteAutoMobile.src,
                alt: "Moritz im Fahrzeug",
            },
            {
                desktopSrc: StartseitePlakatDesktop.src,
                alt: "Arbeitsbeispiel",
            },
        ]}
    />

    <section class="content-section container py-5">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="contact-card h-100">
                    <i class="bi bi-geo-alt"></i>
                    <h3>Standort</h3>
                    <p>{contactDetails.addressLine1}</p>
                    <p>{contactDetails.addressLine2}</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="contact-card h-100">
                    <i class="bi bi-chat-dots"></i>
                    <h3>Erreichbarkeit</h3>
                    <p>Telefon: {contactDetails.phone}</p>
                    <p>Email: {contactDetails.email}</p>
                    <p>Von Montag bis Freitag: 07:00-15:00</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-12">
                <div class="contact-card h-100">
                    <i class="bi bi-instagram"></i>
                    <h3>Social Media</h3>
                    <p>
                        Aktuelle Einblicke und Projekte finden Sie auf
                        Instagram.
                    </p>
                    <a
                        class="btn btn-success"
                        href={contactDetails.instagramUrl}
                        target="_blank"
                        rel="noreferrer"
                    >
                        {contactDetails.instagramHandle}
                    </a>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-1 align-items-stretch">
            <div class="col-lg-5">
                <div class="contact-card accent-card h-100">
                    <span class="eyebrow">Anfrage</span>
                    <h3>Schnell und unkompliziert Kontakt aufnehmen</h3>
                    <p>
                        Nutzen Sie das Kontaktformular für Ihre Anfrage.
                        Beschreiben Sie kurz Ihr Vorhaben, den gewünschten
                        Zeitraum und falls vorhanden erste Maße oder Bilder.
                    </p>
                    <button
                        class="btn btn-success btn-lg"
                        data-bs-toggle="modal"
                        data-bs-target="#contactModal"
                    >
                        Kontaktformular öffnen
                    </button>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="map-card h-100">
                    <iframe
                        src={contactDetails.mapsEmbedUrl}
                        title="Standort von Moritz Zimmer"
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        allowfullscreen></iframe>
                </div>
            </div>
        </div>
    </section>

    <KontaktModal />
    <KontaktArten />
</Baselayout>

<style>
    .content-section {
        color: var(--bs-success);
    }

    .contact-card,
    .map-card {
        height: 100%;
        padding: 2rem;
        border-radius: 1rem;
        background-color: rgba(var(--bs-secondary-rgb), 0.15);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    }

    .accent-card {
        background-color: rgba(var(--bs-secondary-rgb), 0.3);
    }

    .contact-card i {
        display: inline-flex;
        margin-bottom: 1rem;
        font-size: 2rem;
    }

    .contact-card p:last-of-type {
        margin-bottom: 0;
    }

    .eyebrow {
        display: inline-block;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .map-card {
        padding: 0;
        overflow: hidden;
    }

    .map-card iframe {
        width: 100%;
        min-height: 100%;
        border: 0;
    }

    @media (max-width: 991px) {
        .map-card iframe {
            min-height: 360px;
        }
    }
</style>
