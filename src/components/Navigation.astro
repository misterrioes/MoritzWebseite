---
import Logo from "@assets/logo.svg";
---

<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <img src={Logo.src} alt="Logo" />
        </a>

        <button
            class="navbar-toggler ms-auto"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNav"
            aria-controls="navbarNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
        >
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav">
                <li class="nav-item active">
                    <a class="nav-link" href="/"
                        ><span class="nav-link-label">Startseite</span></a
                    >
                </li>
                <li class="nav-item dropdown nav-dropdown-hover">
                    <a
                        class="nav-link dropdown-toggle"
                        href="/"
                        role="button"
                        data-bs-toggle="dropdown"
                        data-bs-auto-close="outside"
                        aria-expanded="false"
                    >
                        <span class="nav-link-label">Dienstleistungen</span>
                    </a>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" href="/natursteinarbeiten">
                                Natursteinarbeiten
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/pflasterarbeiten">
                                Pflasterarbeiten
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/baggerarbeiten">
                                Baggerarbeiten
                            </a>
                        </li>
                    </ul>
                </li>
                <!--        <li class="nav-item">
                    <a class="nav-link" href="#">Antikbaustoffe</a>
                </li> -->
                <li class="nav-item">
                    <a class="nav-link" href="/ueber-mich"
                        ><span class="nav-link-label">Über mich</span></a
                    >
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/kontakt"
                        ><span class="nav-link-label">Kontakt</span></a
                    >
                </li>
            </ul>
        </div>
    </div>
</nav>

<style>
    .navbar {
        background: linear-gradient(
            90deg,
            rgba(var(--bs-primary-rgb), 1) 0%,
            rgba(37, 103, 13, 1) 100%
        );
    }

    .navbar * {
        z-index: 3;
        color: var(--bs-success);
        font-size: 1.375rem;
    }

    .navbar-nav {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        gap: 0.75rem;
    }

    .navbar-nav .nav-link {
        border: 0;
        box-shadow: none;
    }

    .navbar-nav .nav-link:focus,
    .navbar-nav .nav-link:focus-visible,
    .navbar-nav .nav-link:hover {
        border-color: transparent;
        box-shadow: none;
        outline: none;
    }

    .navbar-nav .nav-link-label {
        display: inline-block;
        padding-bottom: 0.15rem;
        border-bottom: 3px solid transparent;
        transition: border-color 0.2s ease;
    }

    .navbar-nav .nav-link:hover .nav-link-label,
    .nav-dropdown-hover:hover .nav-link-label {
        border-bottom-color: var(--bs-secondary);
    }

    nav .dropdown-item:hover {
        background-color: rgba(var(--bs-secondary-rgb), 0.5);
    }

    @media (min-width: 992px) {
        .nav-dropdown-hover .dropdown-menu {
            margin-top: 0;
        }
    }

    @media (max-width: 991px) {
        .navbar-nav {
            position: static;
            transform: none;
            text-align: center;
            width: 100%;
        }
    }

    .navbar-brand img {
        width: 15vw;
        max-width: 150px;
        min-width: 80px;
        height: auto;
    }
</style>

<script>
    const desktopQuery = window.matchMedia("(min-width: 992px)");

    const initHoverDropdowns = () => {
        const dropdownItems = document.querySelectorAll(".nav-dropdown-hover");

        dropdownItems.forEach((item) => {
            if (item.dataset.hoverInit === "true") {
                return;
            }

            const toggle = item.querySelector('[data-bs-toggle="dropdown"]');

            if (!toggle || !window.bootstrap?.Dropdown) {
                return;
            }

            const dropdown =
                window.bootstrap.Dropdown.getOrCreateInstance(toggle);

            item.addEventListener("mouseenter", () => {
                if (desktopQuery.matches) {
                    dropdown.show();
                }
            });

            item.addEventListener("mouseleave", () => {
                if (desktopQuery.matches) {
                    dropdown.hide();
                }
            });

            item.dataset.hoverInit = "true";
        });
    };

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initHoverDropdowns, {
            once: true,
        });
    } else {
        initHoverDropdowns();
    }
</script>
