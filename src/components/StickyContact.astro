---
import { contactDetails } from "./contactData";
---

<div class="sticky-contact">
    <a
        href={`https://wa.me/${contactDetails.phone}`}
        target="_blank"
        rel="noopener"
    >
        <i class="bi bi-whatsapp"></i>
        <p>whatsapp</p>
    </a>
    <a href={contactDetails.email}>
        <i class="bi bi-envelope"></i>
        <p>Email</p>
    </a>
    <a href={"tel:${contactDetails.phone}"}>
        <i class="bi bi-telephone"></i>
        <p>Telefon</p>
    </a>
    <a href={contactDetails.instagramUrl} target="_blank">
        <i class="bi bi-instagram"></i>
        <p>Instagram</p>
    </a>
    <style>
        .sticky-contact {
            position: fixed;
            padding: 10px;
            top: 126px; /* 10% von oben */
            /* 5% von links */
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background-color: #fff;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
            z-index: 2;
            text-align: center;
        }

        .sticky-contact p {
            margin-bottom: 0px;
            margin-left: 5px;
        }

        .sticky-contact a {
            color: #000;
            text-decoration: underline;
            font-size: 24px;
            display: flex; /* Fügt die Icons und Texte nebeneinander */
            align-items: center; /* Zentriert die Icons und Texte vertikal */
        }

        /* Für kleine Bildschirme */
        @media (max-width: 768px) {
            .sticky-contact {
                top: auto; /* Entfernt die feste Position von oben */
                bottom: 2vh; /* Platziert das Div 2% von unten, skaliert mit Viewport */
                left: 50%; /* Zentriert horizontal */
                transform: translateX(-50%);
                flex-direction: row; /* Icons und Texte nebeneinander auf einer Zeile */
                padding: 1vh 4vw; /* Skaliert Padding mit Viewport */
                max-width: 90vw; /* Verhindert Überlauf auf kleinen Bildschirmen */
                gap: 1vw; /* Abstand zwischen den Links */
            }
            .sticky-contact a {
                font-size: 4vw; /* Skaliert Schriftgröße mit Viewport */
            }
        }

        .sticky-contact.hidden {
            display: none;
        }
    </style>

    <!--- The StickyContact hides when the user scrolls completely to the bottom of the page. Here's what I added:    -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const sticky = document.querySelector(".sticky-contact");
            const checkScroll = () => {
                if (
                    window.scrollY + window.innerHeight >=
                        document.documentElement.scrollHeight - 10 &&
                    window.matchMedia("(max-width: 768px)").matches
                ) {
                    sticky.classList.add("hidden");
                } else {
                    sticky.classList.remove("hidden");
                }
            };
            window.addEventListener("scroll", checkScroll);
            checkScroll(); // Initial check
        });
    </script>
</div>
