---
import Bild1 from "@images/StartseiteFensterEingemauert1zu1.jpg";
import Bild2 from "@images/Startseite1zu1Pflaster.jpg";
import Bild3 from "@images/Startseite1zu1MoritzImBagger.jpg";
---

<h2>Dienstleistungen</h2>

<div class="container-fluid">
    <div class="row">
        <div class="col-xxl-4 col-md-6 col-sm-12">
            <a href="/natursteinarbeiten" class="text-decoration-none">
                <div class="image-container">
                    <img src={Bild1.src} alt="Image" class="image" />
                    <div class="overlay-box-heading">
                        <h3 class="imageHeading">Natursteinarbeiten</h3>
                    </div>
                    <div class="overlay-box">
                        <p>Hover Text 1</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xxl-4 col-md-6 col-sm-12">
            <a href="/pflasterarbeiten" class="text-decoration-none">
                <div class="image-container">
                    <img src={Bild2.src} alt="Image" class="image" />
                    <div class="overlay-box-heading">
                        <h3 class="imageHeading">Pflasterarbeiten</h3>
                    </div>
                    <div class="overlay-box">
                        <p>Hover Text 2</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xxl-4 col-md-6 offset-md-3 offset-xxl-0 col-sm-12">
            <a href="/baggerarbeiten" class="text-decoration-none">
                <div class="image-container">
                    <img src={Bild3.src} alt="Image" class="image" />
                    <div class="overlay-box-heading">
                        <h3 class="imageHeading">Baggerarbeiten</h3>
                    </div>
                    <div class="overlay-box">
                        <p>Hover Text 3</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    a.text-decoration-none {
        display: block;
    }

    .image-container {
        position: relative;
        padding: 10px;
        margin: 0.5rem 0;
        width: 100%;
        height: 500px;
        overflow: hidden;
        border-radius: 18px;
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            outline-color 0.2s ease;
    }

    .image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease-in-out;
    }

    .overlay-box-heading {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        color: rgba(var(--bs-primary-rgb), 1);
        display: flex;
        justify-content: center;
        text-align: center;
        align-items: center;
        opacity: 1;
    }

    .overlay-box {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(var(--bs-secondary-rgb), 0.5);
        color: rgba(var(--bs-primary-rgb), 1);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s ease-in-out;
    }

    @media (max-width: 1199px) {
        .image-container {
            cursor: pointer;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.16);
            outline: 2px solid rgba(var(--bs-success-rgb), 0.2);
            outline-offset: -2px;
        }

        a.text-decoration-none:active .image-container,
        a.text-decoration-none:focus-visible .image-container {
            transform: scale(0.98);
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.2);
            outline-color: rgba(var(--bs-success-rgb), 0.55);
        }

        .overlay-box-heading {
            background: linear-gradient(
                to top,
                rgba(0, 0, 0, 0.45),
                rgba(0, 0, 0, 0.08)
            );
        }
    }

    @media (min-width: 576px) {
        .image-container:hover .image {
            transform: scale(1.1);
        }

        .image-container:hover .overlay-box {
            opacity: 1;
        }

        .image-container:hover .overlay-box-heading {
            display: none;
        }
    }
</style>
